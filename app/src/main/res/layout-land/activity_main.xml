<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- 左侧导航区 - 固定宽度 72dp -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/navRail"
        android:layout_width="72dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="24dp"
            android:clickable="false"
            android:focusable="false">

            <!-- Logo -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_music_note"
                android:tint="@color/primary"
                android:layout_marginBottom="32dp"/>

            <!-- 导航项 -->
            <FrameLayout
                android:id="@+id/navHome"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/navHomeIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_home"
                    android:tint="@color/primary"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"/>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/navSearch"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/navSearchIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_search"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"/>
            </FrameLayout>

            <FrameLayout
                android:id="@+id/navLibrary"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:layout_marginBottom="8dp"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/navLibraryIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_library"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"/>
            </FrameLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <FrameLayout
                android:id="@+id/navSettings"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/navSettingsIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/text_secondary"
                    android:layout_gravity="center"
                    android:clickable="false"
                    android:focusable="false"/>
            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 中央内容区 - 主舞台 -->
    <FrameLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintBottom_toTopOf="@id/miniPlayerContainer"
        app:layout_constraintEnd_toStartOf="@id/rightPanel"
        app:layout_constraintStart_toEndOf="@id/navRail"
        app:layout_constraintTop_toTopOf="parent">

        <!-- 动态加载 Fragment -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/app_name"/>

    </FrameLayout>

    <!-- 右侧信息区 - 可折叠 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/rightPanel"
        android:layout_width="280dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:clickable="false"
        android:focusable="false"
        app:cardBackgroundColor="@color/surface"
        app:cardCornerRadius="16dp"
        app:cardElevation="2dp"
        app:layout_constraintBottom_toTopOf="@id/miniPlayerContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- 标题栏 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="播放队列"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:padding="16dp"/>

            <!-- 播放队列列表 -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPlaylist"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:paddingHorizontal="12dp"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- 底部迷你播放器 -->
    <FrameLayout
        android:id="@+id/miniPlayerContainer"
        android:layout_width="0dp"
        android:layout_height="80dp"
        android:background="@color/surface"
        android:elevation="8dp"
        app:layout_constraintStart_toEndOf="@id/navRail"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <include layout="@layout/mini_player_land"/>

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>