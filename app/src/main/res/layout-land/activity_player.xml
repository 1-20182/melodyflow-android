<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <!-- Background overlay for blur effect -->
    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@color/background" />

    <!-- Dynamic background - album cover blur -->
    <ImageView
        android:id="@+id/bgBlurImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:alpha="0.15"
        android:visibility="visible" />

    <!-- Gradient mask -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_player_gradient"
        android:alpha="0.9"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="@dimen/spacing_lg"
        android:paddingVertical="@dimen/spacing_sm"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="@dimen/control_button_default"
            android:layout_height="@dimen/control_button_default"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/player_close"
            android:src="@drawable/ic_expand_more"
            android:rotation="180"
            app:tint="@color/text_primary" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- Song info - centered in top bar -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_large"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="200dp" />

            <TextView
                android:id="@+id/tvArtist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_size_small"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"
                android:maxWidth="200dp" />
        </LinearLayout>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/btnFavorite"
            android:layout_width="@dimen/control_button_default"
            android:layout_height="@dimen/control_button_default"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/player_favorite"
            android:src="@drawable/ic_favorite_border"
            app:tint="@color/primary" />

        <ImageButton
            android:id="@+id/btnLyrics"
            android:layout_width="@dimen/control_button_default"
            android:layout_height="@dimen/control_button_default"
            android:layout_marginEnd="@dimen/spacing_sm"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="查看歌词"
            android:src="@drawable/ic_lyrics"
            app:tint="@color/text_primary" />

        <ImageButton
            android:id="@+id/btnMore"
            android:layout_width="@dimen/control_button_default"
            android:layout_height="@dimen/control_button_default"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="更多选项"
            android:src="@drawable/ic_more"
            app:tint="@color/text_primary" />
    </LinearLayout>

    <!-- Main content area: side-by-side layout -->
    <LinearLayout
        android:id="@+id/mainContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingHorizontal="@dimen/spacing_xl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/bottomSection">

        <!-- Left panel: Cover art -->
        <FrameLayout
            android:id="@+id/coverContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="@dimen/spacing_xl"
            android:layout_gravity="center">

            <!-- Vinyl record background -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/cover_size_player_land"
                android:layout_height="@dimen/cover_size_player_land"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/cover_size_player_land"
                app:cardElevation="16dp"
                app:strokeColor="@color/vinyl_groove"
                app:strokeWidth="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/vinyl_grooves" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Album cover -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coverCard"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_gravity="center"
                app:cardCornerRadius="100dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="专辑封面"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Center hole -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/vinyl_record_center"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/vinyl_center_inner"
                app:strokeWidth="1dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/vinyl_center" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Play overlay -->
            <FrameLayout
                android:id="@+id/coverPlayOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@color/cover_play_overlay"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/btnCoverPlay"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_primary"
                    android:contentDescription="播放/暂停"
                    android:elevation="8dp"
                    android:padding="20dp"
                    android:src="@drawable/ic_play"
                    app:tint="@color/background" />
            </FrameLayout>
        </FrameLayout>

        <!-- Right panel: Lyrics preview -->
        <FrameLayout
            android:id="@+id/lyricsPreviewContainer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLyricsPreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:paddingTop="40dp"
                android:paddingBottom="40dp" />

            <TextView
                android:id="@+id/tvNoLyricsPreview"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="暂无歌词"
                android:textColor="@color/text_tertiary"
                android:textSize="16sp"
                android:visibility="gone" />

            <!-- Hint: swipe for fullscreen lyrics -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center|bottom"
                android:layout_marginBottom="8dp"
                android:text="左右滑动查看歌词"
                android:textSize="12sp"
                android:textColor="@color/text_tertiary"
                android:alpha="0.5" />
        </FrameLayout>
    </LinearLayout>

    <!-- Bottom section: Progress + Controls -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/spacing_xl"
        android:paddingBottom="@dimen/spacing_md"
        android:paddingTop="@dimen/spacing_sm"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Progress Container -->
        <LinearLayout
            android:id="@+id/progressContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- MD3 Slider -->
            <com.google.android.material.slider.Slider
                android:id="@+id/seekBar"
                style="@style/Widget.MelodyFlow.Slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:valueFrom="0"
                android:valueTo="100" />

            <!-- Time labels -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginTop="@dimen/spacing_xs"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvCurrentTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_size_small"
                    android:fontFeatureSettings="tnum" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tvTotalTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0:00"
                    android:textColor="@color/text_tertiary"
                    android:textSize="@dimen/text_size_small"
                    android:fontFeatureSettings="tnum" />
            </LinearLayout>
        </LinearLayout>

        <!-- Playback controls -->
        <LinearLayout
            android:id="@+id/playerControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_sm">

            <ImageButton
                android:id="@+id/btnPlayMode"
                android:layout_width="@dimen/control_button_default"
                android:layout_height="@dimen/control_button_default"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_play_mode"
                android:src="@drawable/ic_repeat"
                app:tint="@color/text_secondary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_previous"
                android:src="@drawable/ic_previous"
                app:tint="@color/text_primary" />

            <!-- Play/Pause - MD3 FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:contentDescription="@string/player_play_pause"
                android:src="@drawable/ic_play"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="?attr/colorOnPrimary"
                app:fabCustomSize="56dp"
                app:fabSize="normal"
                app:elevation="6dp"
                app:pressedTranslationZ="12dp" />

            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_next"
                android:src="@drawable/ic_next"
                app:tint="@color/text_primary" />

            <View
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ImageButton
                android:id="@+id/btnPlaylist"
                android:layout_width="@dimen/control_button_default"
                android:layout_height="@dimen/control_button_default"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_playlist"
                android:src="@drawable/ic_playlist"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>

    <!-- Lyrics Focus Overlay (fullscreen) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/lyricsFocusOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <View
            android:id="@+id/lyricsBackground"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha="0.95"
            android:background="@color/background" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLyricsFocus"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:paddingTop="100dp"
            android:paddingBottom="100dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.85" />

        <TextView
            android:id="@+id/tvNoLyricsFocus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="暂无歌词"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_size_body"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Close lyrics button - on top layer -->
    <ImageButton
        android:id="@+id/btnCloseLyrics"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="关闭歌词"
        android:src="@drawable/ic_expand_more"
        android:rotation="180"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

</androidx.constraintlayout.widget.ConstraintLayout>
