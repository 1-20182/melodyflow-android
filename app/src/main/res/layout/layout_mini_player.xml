<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayerContainer"
    android:layout_width="match_parent"
    android:layout_height="@dimen/mini_player_height"
    android:background="@drawable/bg_glass_card"
    android:clickable="true"
    android:contentDescription="迷你播放器"
    android:focusable="true"
    android:elevation="8dp">

    <!-- Vinyl record style cover -->
    <FrameLayout
        android:id="@+id/miniCoverContainer"
        android:layout_width="@dimen/cover_size_mini"
        android:layout_height="@dimen/cover_size_mini"
        android:layout_marginStart="@dimen/spacing_md"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        
        <!-- Background vinyl circle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/vinyl_center_inner"
            app:cardCornerRadius="@dimen/cover_size_mini"
            app:cardElevation="4dp"
            app:strokeColor="@color/vinyl_groove"
            app:strokeWidth="1dp">
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/vinyl_grooves" />
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Album cover circle -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:layout_margin="6dp"
            app:cardCornerRadius="@dimen/cover_size_mini"
            app:cardElevation="2dp">
            <ImageView
                android:id="@+id/ivMiniCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="封面"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note" />
        </com.google.android.material.card.MaterialCardView>
        
        <!-- Center hole -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/vinyl_record_center"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp" />
    </FrameLayout>

    <!-- Song title -->
    <TextView
        android:id="@+id/tvMiniTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_subtitle"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvMiniArtist"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPrevious"
        app:layout_constraintStart_toEndOf="@id/ivMiniCover"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <!-- Artist name -->
    <TextView
        android:id="@+id/tvMiniArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/spacing_md"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_body"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPrevious"
        app:layout_constraintStart_toEndOf="@id/ivMiniCover"
        app:layout_constraintTop_toBottomOf="@id/tvMiniTitle" />

    <!-- Previous button -->
    <ImageButton
        android:id="@+id/btnMiniPrevious"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="上一曲"
        android:src="@drawable/ic_previous"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniPlay"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

    <!-- Play/Pause button -->
    <ImageButton
        android:id="@+id/btnMiniPlay"
        android:layout_width="@dimen/control_button_large"
        android:layout_height="@dimen/control_button_large"
        android:layout_marginEnd="@dimen/spacing_xs"
        android:background="@drawable/bg_play_button"
        android:contentDescription="播放/暂停"
        android:src="@drawable/ic_play"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnMiniNext"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_on_primary" />

    <!-- Next button -->
    <ImageButton
        android:id="@+id/btnMiniNext"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="下一曲"
        android:src="@drawable/ic_next"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_secondary" />

</androidx.constraintlayout.widget.ConstraintLayout>
