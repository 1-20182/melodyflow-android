<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fitsSystemWindows="true">

    <!-- Toolbar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/glass_background"
        android:elevation="0dp"
        app:navigationIcon="@drawable/ic_close"
        app:title="@string/library_settings"
        app:titleTextColor="@color/text_primary" />

    <!-- Scrollable content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:padding="@dimen/spacing_base">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Image Cache Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="图片缓存"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_base"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="缓存大小"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_subtitle" />

                        <TextView
                            android:id="@+id/tvCacheSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_subtitle" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="Glide 图片缓存"
                        android:textColor="@color/text_disabled"
                        android:textSize="@dimen/text_size_body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearCache"
                        style="@style/Widget.MelodyFlow.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="清除图片缓存" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Music Cache Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="音乐缓存"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_base"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="缓存大小"
                            android:textColor="@color/text_secondary"
                            android:textSize="@dimen/text_size_subtitle" />

                        <TextView
                            android:id="@+id/tvMusicCacheSize"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0 MB (0 首歌曲)"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_subtitle" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="已下载的音乐文件（支持离线播放）"
                        android:textColor="@color/text_disabled"
                        android:textSize="@dimen/text_size_body" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnClearMusicCache"
                        style="@style/Widget.MelodyFlow.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="清除音乐缓存"
                        app:backgroundTint="@color/accent" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Startup Page Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="启动页面"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="选择启动应用时默认显示的页面"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <RadioGroup
                        android:id="@+id/rgStartupPage"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="vertical">

                        <RadioButton
                            android:id="@+id/rbStartupHome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="主页（推荐、排行榜）"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_subtitle" />

                        <RadioButton
                            android:id="@+id/rbStartupAI"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="AI音乐推荐"
                            android:textColor="@color/text_primary"
                            android:textSize="@dimen/text_size_subtitle" />
                    </RadioGroup>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- AI Recommendation Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AI音乐推荐"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="配置AI API，获取个性化歌曲推荐"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAISettings"
                        style="@style/Widget.MelodyFlow.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="AI推荐设置" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Gradient Preset Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="渐变背景预设"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="选择一个预设的渐变色作为应用背景"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <RadioGroup
                        android:id="@+id/gradientPresetGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:orientation="horizontal"
                        android:weightSum="6" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Custom Background Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_base">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="自定义背景图片"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_section"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="选择一张图片作为应用背景"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <ImageView
                        android:id="@+id/ivBackgroundPreview"
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:background="@color/surface_variant"
                        android:contentDescription="背景预览"
                        android:scaleType="centerCrop" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSelectBackground"
                        style="@style/Widget.MelodyFlow.Button.Primary"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="选择图片" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnResetBackground"
                        style="@style/Widget.MelodyFlow.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_sm"
                        android:text="恢复默认" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- About Card -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.MelodyFlow.GlassCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_xl">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MelodyFlow"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/spacing_xs"
                        android:text="@string/setting_version"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_size_subtitle" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewChangelog"
                        style="@style/Widget.MelodyFlow.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        android:layout_marginTop="@dimen/spacing_md"
                        android:text="查看更新日志" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
