<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="@dimen/spacing_xxl">

    <!-- Vinyl record container -->
    <FrameLayout
        android:id="@+id/coverContainer"
        android:layout_width="@dimen/cover_size_player"
        android:layout_height="@dimen/cover_size_player"
        android:layout_gravity="center"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed">

        <!-- Vinyl record background with grooves -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            app:cardBackgroundColor="#0A0A0A"
            app:cardCornerRadius="@dimen/cover_size_player"
            app:cardElevation="16dp"
            app:strokeColor="#1A1A1A"
            app:strokeWidth="2dp">
            
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/vinyl_grooves" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Album cover - displayed in the center with margin for vinyl border -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/coverCard"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:layout_gravity="center"
            app:cardCornerRadius="100dp"
            app:cardElevation="4dp">
            
            <ImageView
                android:id="@+id/ivCover"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:contentDescription="专辑封面"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_music_note" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Center hole -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="#121212"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:strokeColor="#0A0A0A"
            app:strokeWidth="1dp">
            
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:background="@drawable/vinyl_center" />
        </com.google.android.material.card.MaterialCardView>

        <!-- Play/Pause overlay -->
        <FrameLayout
            android:id="@+id/coverPlayOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:alpha="0"
            android:background="#40000000"
            android:clickable="true"
            android:focusable="true">

            <ImageButton
                android:id="@+id/btnCoverPlay"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_circle_primary"
                android:contentDescription="播放/暂停"
                android:elevation="8dp"
                android:padding="20dp"
                android:src="@drawable/ic_play"
                app:tint="@color/background" />
        </FrameLayout>
    </FrameLayout>

    <!-- Song title -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginTop="@dimen/spacing_xl"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_player_title"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvArtist"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/coverContainer" />

    <!-- Artist name -->
    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_player_artist"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

</androidx.constraintlayout.widget.ConstraintLayout>