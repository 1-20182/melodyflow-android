<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clipToPadding="false"
    android:fitsSystemWindows="true">

    <!-- Background overlay for blur effect -->
    <View
        android:id="@+id/backgroundOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@color/background" />

    <!-- Top bar - Subtle and minimal -->
    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginStart="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/player_close"
        android:src="@drawable/ic_close"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_primary" />

    <TextView
        android:id="@+id/tvNowPlaying"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/player_now_playing"
        android:textColor="@color/text_tertiary"
        android:textSize="@dimen/text_size_small"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        app:layout_constraintBottom_toBottomOf="@id/btnClose"
        app:layout_constraintEnd_toEndOf="@id/btnFavorite"
        app:layout_constraintStart_toEndOf="@id/btnClose"
        app:layout_constraintTop_toTopOf="@id/btnClose" />

    <ImageButton
        android:id="@+id/btnFavorite"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/player_favorite"
        android:src="@drawable/ic_favorite_border"
        app:layout_constraintEnd_toStartOf="@id/btnLyrics"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/primary" />

    <ImageButton
        android:id="@+id/btnLyrics"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginEnd="@dimen/spacing_sm"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="查看歌词"
        android:src="@drawable/ic_lyrics"
        app:layout_constraintEnd_toStartOf="@id/btnMore"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_primary" />

    <ImageButton
        android:id="@+id/btnMore"
        android:layout_width="@dimen/control_button_default"
        android:layout_height="@dimen/control_button_default"
        android:layout_marginEnd="@dimen/spacing_lg"
        android:layout_marginTop="@dimen/spacing_lg"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="更多选项"
        android:src="@drawable/ic_more"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/text_primary" />

    <!-- Playback Card Container -->
    <FrameLayout
        android:id="@+id/cardContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/spacing_xl"
        android:layout_marginBottom="@dimen/spacing_md"
        android:clipToOutline="true"
        android:outlineProvider="bounds"
        app:layout_constraintBottom_toTopOf="@id/progressContainer"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvNowPlaying"
        app:layout_constraintWidth_percent="0.7">

        <!-- Cover Content (replaces FragmentContainerView) -->
        <FrameLayout
            android:id="@+id/coverContainer"
            android:layout_width="@dimen/cover_size_player"
            android:layout_height="@dimen/cover_size_player"
            android:layout_gravity="center">

            <!-- Vinyl record background - must be first (bottom layer) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:cardBackgroundColor="@android:color/transparent"
                app:cardCornerRadius="@dimen/cover_size_player"
                app:cardElevation="16dp"
                app:strokeColor="@color/vinyl_groove"
                app:strokeWidth="2dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/vinyl_grooves" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Album cover - must be after vinyl (top layer) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/coverCard"
                android:layout_width="190dp"
                android:layout_height="190dp"
                android:layout_gravity="center"
                app:cardCornerRadius="95dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@android:color/transparent"
                app:strokeWidth="0dp">

                <ImageView
                    android:id="@+id/ivCover"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="专辑封面"
                    android:scaleType="centerCrop"
                    android:background="@android:color/transparent" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Center hole - must be last (topmost layer) -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/vinyl_record_center"
                app:cardCornerRadius="16dp"
                app:cardElevation="4dp"
                app:strokeColor="@color/vinyl_center_inner"
                app:strokeWidth="1dp">

                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:background="@drawable/vinyl_center" />
            </com.google.android.material.card.MaterialCardView>

            <!-- Play overlay -->
            <FrameLayout
                android:id="@+id/coverPlayOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                android:alpha="0"
                android:background="@color/cover_play_overlay"
                android:clickable="true"
                android:focusable="true"
                android:visibility="gone">

                <ImageButton
                    android:id="@+id/btnCoverPlay"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_gravity="center"
                    android:background="@drawable/bg_circle_primary"
                    android:contentDescription="播放/暂停"
                    android:elevation="8dp"
                    android:padding="20dp"
                    android:src="@drawable/ic_play"
                    app:tint="@color/background" />
            </FrameLayout>
        </FrameLayout>

        <!-- Lyrics Focus Overlay (inlined) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/lyricsFocusOverlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <View
                android:id="@+id/lyricsBackground"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:alpha="0.95"
                android:background="@color/background" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvLyricsFocus"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:clipToPadding="false"
                android:paddingTop="100dp"
                android:paddingBottom="100dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintWidth_percent="0.85" />

            <TextView
                android:id="@+id/tvNoLyricsFocus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="暂无歌词"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_size_body"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <ImageButton
                android:id="@+id/btnCloseLyrics"
                android:layout_width="@dimen/control_button_default"
                android:layout_height="@dimen/control_button_default"
                android:layout_marginTop="@dimen/spacing_lg"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="关闭歌词"
                android:src="@drawable/ic_expand_more"
                android:rotation="180"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/text_secondary" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>

    <!-- Song title and artist -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginTop="@dimen/spacing_sm"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text_primary"
        android:textSize="@dimen/text_size_player_title"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/tvArtist"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/cardContainer" />

    <TextView
        android:id="@+id/tvArtist"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_base"
        android:layout_marginTop="@dimen/spacing_xs"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:textColor="@color/text_secondary"
        android:textSize="@dimen/text_size_player_artist"
        app:layout_constraintBottom_toTopOf="@id/lyricsPreviewContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- 歌词预览区域 -->
    <FrameLayout
        android:id="@+id/lyricsPreviewContainer"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="@dimen/spacing_xl"
        android:layout_marginTop="@dimen/spacing_sm"
        android:layout_marginBottom="@dimen/spacing_sm"
        app:layout_constraintBottom_toTopOf="@id/progressContainer"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvArtist">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvLyricsPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingVertical="20dp" />

        <TextView
            android:id="@+id/tvNoLyricsPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="暂无歌词"
            android:textColor="@color/text_tertiary"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- 提示：左右滑动查看全屏歌词 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center|bottom"
            android:layout_marginBottom="2dp"
            android:text="左右滑动查看歌词"
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:alpha="0.5" />

    </FrameLayout>

    <!-- Progress Container -->
    <LinearLayout
        android:id="@+id/progressContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/spacing_xl"
        android:gravity="center_vertical"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/playerControls"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Slider -->
        <com.google.android.material.slider.Slider
            android:id="@+id/seekBar"
            style="@style/Widget.MelodyFlow.Slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100" />

        <!-- Time labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:layout_marginTop="@dimen/spacing_xs"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvCurrentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_size_small"
                android:fontFeatureSettings="tnum" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tvTotalTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textColor="@color/text_tertiary"
                android:textSize="@dimen/text_size_small"
                android:fontFeatureSettings="tnum" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom control bar - Clean and minimal -->
    <LinearLayout
        android:id="@+id/playerControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingVertical="@dimen/spacing_lg"
        android:paddingBottom="@dimen/spacing_xxl"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Control buttons - Symmetric layout -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal">

            <!-- Play Mode -->
            <ImageButton
                android:id="@+id/btnPlayMode"
                android:layout_width="@dimen/control_button_default"
                android:layout_height="@dimen/control_button_default"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_play_mode"
                android:src="@drawable/ic_repeat"
                app:tint="@color/text_secondary" />

            <!-- Spacer for balance -->
            <View
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="1dp" />

            <!-- Previous -->
            <ImageButton
                android:id="@+id/btnPrevious"
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_previous"
                android:src="@drawable/ic_previous"
                app:tint="@color/text_primary" />

            <!-- Spacer -->
            <View
                android:layout_width="@dimen/spacing_lg"
                android:layout_height="1dp" />

            <!-- Play/Pause - MD3 FAB -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnPlayPause"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="@dimen/spacing_lg"
                android:contentDescription="@string/player_play_pause"
                android:src="@drawable/ic_play"
                app:backgroundTint="?attr/colorPrimary"
                app:tint="?attr/colorOnPrimary"
                app:fabCustomSize="64dp"
                app:fabSize="normal"
                app:elevation="6dp"
                app:pressedTranslationZ="12dp" />

            <!-- Spacer -->
            <View
                android:layout_width="@dimen/spacing_lg"
                android:layout_height="1dp" />

            <!-- Next -->
            <ImageButton
                android:id="@+id/btnNext"
                android:layout_width="@dimen/icon_size_xlarge"
                android:layout_height="@dimen/icon_size_xlarge"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_next"
                android:src="@drawable/ic_next"
                app:tint="@color/text_primary" />

            <!-- Spacer for balance -->
            <View
                android:layout_width="@dimen/spacing_xl"
                android:layout_height="1dp" />

            <!-- Playlist -->
            <ImageButton
                android:id="@+id/btnPlaylist"
                android:layout_width="@dimen/control_button_default"
                android:layout_height="@dimen/control_button_default"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/player_playlist"
                android:src="@drawable/ic_playlist"
                app:tint="@color/text_secondary" />
        </LinearLayout>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
