<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Input card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/Widget.MelodyFlow.GlassCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_base">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/import_url_hint"
                    app:boxBackgroundColor="@color/surface_variant"
                    app:boxCornerRadiusBottomEnd="@dimen/corner_radius_small"
                    app:boxCornerRadiusBottomStart="@dimen/corner_radius_small"
                    app:boxCornerRadiusTopEnd="@dimen/corner_radius_small"
                    app:boxCornerRadiusTopStart="@dimen/corner_radius_small"
                    app:boxStrokeColor="@color/divider"
                    app:hintTextColor="@color/text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etPlaylistUrl"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textUri"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:textSize="@dimen/text_size_subtitle" />
                </com.google.android.material.textfield.TextInputLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:text="@string/import_url_example"
                    android:textColor="@color/text_disabled"
                    android:textSize="@dimen/text_size_body" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnParseUrl"
                    style="@style/Widget.MelodyFlow.Button.Primary"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:layout_marginTop="@dimen/spacing_md"
                    android:text="@string/import_parse" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/progressBarUrl"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_xl"
            android:visibility="gone" />

        <!-- Empty state -->
        <TextView
            android:id="@+id/tvUrlEmpty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/spacing_xxl"
            android:text="@string/import_empty"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:visibility="visible" />

        <!-- Results list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvUrlResults"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_base"
            android:clipToPadding="false"
            android:paddingBottom="@dimen/spacing_base"
            android:visibility="gone"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
