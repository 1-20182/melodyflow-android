<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outer ring grooves - transparent background -->
    <item>
        <shape android:shape="oval">
            <size android:width="300dp" android:height="300dp" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>

    <!-- Inner groove 1 -->
    <item android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A1A1A" />
        </shape>
    </item>

    <!-- Inner groove 2 -->
    <item android:left="24dp" android:top="24dp" android:right="24dp" android:bottom="24dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A1A1A" />
        </shape>
    </item>

    <!-- Inner groove 3 -->
    <item android:left="36dp" android:top="36dp" android:right="36dp" android:bottom="36dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A1A1A" />
        </shape>
    </item>

    <!-- Inner groove 4 -->
    <item android:left="48dp" android:top="48dp" android:right="48dp" android:bottom="48dp">
        <shape android:shape="oval">
            <stroke android:width="1dp" android:color="#1A1A1A" />
        </shape>
    </item>
</layer-list>