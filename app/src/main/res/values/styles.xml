<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Text Appearances - Clear visual hierarchy -->
    <style name="TextAppearance.MelodyFlow.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.MelodyFlow.Subtitle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <style name="TextAppearance.MelodyFlow.Body" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.MelodyFlow.BottomNav.Active" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="TextAppearance.MelodyFlow.BottomNav.Inactive" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Widgets -->
    <style name="Widget.MelodyFlow.BottomNav" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconSize">26dp</item>
        <item name="itemTextAppearanceActive">@style/TextAppearance.MelodyFlow.BottomNav.Active</item>
        <item name="itemTextAppearanceInactive">@style/TextAppearance.MelodyFlow.BottomNav.Inactive</item>
        <item name="itemPaddingTop">6dp</item>
        <item name="itemPaddingBottom">6dp</item>
        <item name="android:elevation">8dp</item>
    </style>

    <style name="Widget.MelodyFlow.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/glass_background</item>
        <item name="cardCornerRadius">@dimen/corner_radius_card</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.MelodyFlow.SurfaceCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/corner_radius_card</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.MelodyFlow.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/background</item>
        <item name="android:textStyle">bold</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.MelodyFlow.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">@dimen/corner_radius_button</item>
        <item name="strokeColor">@color/divider</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="Widget.MelodyFlow.Slider" parent="Widget.MaterialComponents.Slider">
        <item name="thumbColor">@color/primary</item>
        <item name="trackColorActive">@color/primary</item>
        <item name="trackColorInactive">@color/surface_variant</item>
        <item name="thumbRadius">6dp</item>
        <item name="trackHeight">4dp</item>
    </style>

    <style name="Widget.MelodyFlow.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="tabIndicatorColor">@color/primary</item>
        <item name="tabSelectedTextColor">@color/primary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabBackground">@android:color/transparent</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabTextAppearance">@style/TextAppearance.MelodyFlow.Subtitle</item>
    </style>

    <style name="Widget.MelodyFlow.SearchInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxCornerRadiusTopStart">@dimen/corner_radius_button</item>
        <item name="boxCornerRadiusTopEnd">@dimen/corner_radius_button</item>
        <item name="boxCornerRadiusBottomStart">@dimen/corner_radius_button</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/corner_radius_button</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="hintTextColor">@color/text_tertiary</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
    </style>

    <!-- Player specific styles -->
    <style name="Widget.MelodyFlow.Player.ControlButton" parent="Widget.MaterialComponents.Button.Icon">
        <item name="cornerRadius">100dp</item>
        <item name="iconSize">28dp</item>
        <item name="elevation">0dp</item>
    </style>
</resources>